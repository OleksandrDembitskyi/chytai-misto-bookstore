{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/(.*\\.(css|js|ico|png|jpg|jpeg|webp|svg))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}